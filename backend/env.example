# Mail Mind Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# To use: cp env.example .env
# Then edit .env with your actual values

# Encryption key for encrypting user data
# Generate with: python scripts/generate_key.py
ENCRYPTION_KEY=your_encryption_key_here

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database URL (defaults to SQLite)
DATABASE_URL=sqlite:///./data/mailmind.db

# API authentication (JWT). Required: without JWT_SECRET the API returns 503 on protected routes.
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
# Access token lifetime in days (default 7 if omitted)
JWT_EXPIRE_DAYS=7
# Optional: if set, POST /api/auth/login must send the same value as login_secret
# (set VITE_AUTH_LOGIN_SECRET in frontend/.env to match when using this)
AUTH_LOGIN_SECRET=

# Gmail OAuth Credentials (for adding accounts via script)
# Get these from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret

# Gmail OAuth Tokens (from scripts/get_gmail_tokens.py)
# These are temporary - they'll be stored encrypted in the database
GMAIL_TOKEN=your-oauth-token
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token

# Account details for scripts/add_gmail_account.py
MAIL_MIND_USERNAME=your_username
GMAIL_ADDRESS=your@gmail.com

# OAuth redirect URLs (optional - defaults provided)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

